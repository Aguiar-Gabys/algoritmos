programa {
  funcao inicio() {
    cadeia nome
    inteiro pontos, idade

    nome = "Douglas"
    pontos = 1500
    idade = 16
    escreva("Olá, mundo! \n")
    escreva(nome, " tem ", idade, "anos de idade.")
    escreva(nome, "tem ", idade, "meses de free fire e apostando em cada jogo, com isso ele conseguiu ganhar ", pontos, " pontos em uma partida")
  }
}
